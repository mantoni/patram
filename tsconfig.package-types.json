{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "types": ["node"]
  },
  "include": [
    "lib/config/**/*.js",
    "lib/config/**/*.types.ts",
    "lib/graph/**/*.js",
    "lib/graph/**/*.types.ts",
    "lib/load-project-graph.js",
    "lib/overlay-graph.js",
    "lib/parse/**/*.js",
    "lib/parse/**/*.types.ts",
    "lib/query-graph.js",
    "lib/tagged-fenced-blocks.js"
  ],
  "exclude": ["**/*.test.js", "**/*.test-helpers.js"]
}
