{
  "include": [
    "docs/**/*.md",
    "bin/**/*.js",
    "lib/**/*.js",
    "scripts/**/*.js",
    "test/**/*.js"
  ],
  "queries": {
    "pending": {
      "where": "kind=task and status=pending"
    },
    "blocked": {
      "where": "kind=task and status=blocked"
    },
    "accepted-decisions": {
      "where": "kind=decision and status=accepted"
    },
    "command-implementations": {
      "where": "implements_command:*"
    },
    "command-taxonomy": {
      "where": "id^=command:"
    },
    "source-entrypoints": {
      "where": "kind=entrypoint"
    },
    "source-cli": {
      "where": "kind=cli"
    },
    "source-config": {
      "where": "kind=config"
    },
    "source-scan": {
      "where": "kind=scan"
    },
    "source-parse": {
      "where": "kind=parse"
    },
    "source-graph": {
      "where": "kind=graph"
    },
    "source-output": {
      "where": "kind=output"
    },
    "source-support": {
      "where": "kind=support"
    },
    "source-release": {
      "where": "kind=release"
    },
    "term-usage": {
      "where": "uses_term:*"
    },
    "term-taxonomy": {
      "where": "id^=term:"
    }
  },
  "kinds": {
    "command": {
      "label": "Command"
    },
    "document": {
      "builtin": true
    },
    "term": {
      "label": "Term"
    }
  },
  "relations": {
    "defines": {
      "from": ["document"],
      "to": ["command", "term"]
    },
    "about_command": {
      "from": ["document"],
      "to": ["command"]
    },
    "links_to": {
      "builtin": true,
      "from": ["document"],
      "to": ["document"]
    },
    "blocked_by": {
      "from": ["document"],
      "to": ["document"]
    },
    "decided_by": {
      "from": ["document"],
      "to": ["document"]
    },
    "implements": {
      "from": ["document"],
      "to": ["document"]
    },
    "implements_command": {
      "from": ["document"],
      "to": ["command"]
    },
    "tracked_in": {
      "from": ["document"],
      "to": ["document"]
    },
    "uses_term": {
      "from": ["document"],
      "to": ["term"]
    }
  },
  "mappings": {
    "document.title": {
      "node": {
        "field": "title",
        "kind": "document"
      }
    },
    "jsdoc.directive.about_command": {
      "emit": {
        "relation": "about_command",
        "target": "path",
        "target_kind": "command"
      }
    },
    "jsdoc.directive.kind": {
      "node": {
        "field": "kind",
        "kind": "document"
      }
    },
    "jsdoc.directive.status": {
      "node": {
        "field": "status",
        "kind": "document"
      }
    },
    "jsdoc.directive.blocked_by": {
      "emit": {
        "relation": "blocked_by",
        "target": "path",
        "target_kind": "document"
      }
    },
    "jsdoc.directive.decided_by": {
      "emit": {
        "relation": "decided_by",
        "target": "path",
        "target_kind": "document"
      }
    },
    "jsdoc.directive.implements": {
      "emit": {
        "relation": "implements",
        "target": "path",
        "target_kind": "document"
      }
    },
    "jsdoc.directive.implements_command": {
      "emit": {
        "relation": "implements_command",
        "target": "path",
        "target_kind": "command"
      }
    },
    "jsdoc.directive.tracked_in": {
      "emit": {
        "relation": "tracked_in",
        "target": "path",
        "target_kind": "document"
      }
    },
    "jsdoc.directive.uses_term": {
      "emit": {
        "relation": "uses_term",
        "target": "path",
        "target_kind": "term"
      }
    },
    "markdown.directive.about_command": {
      "emit": {
        "relation": "about_command",
        "target": "path",
        "target_kind": "command"
      }
    },
    "markdown.directive.command": {
      "emit": {
        "relation": "defines",
        "target": "value",
        "target_kind": "command"
      },
      "node": {
        "field": "title",
        "key": "value",
        "kind": "command"
      }
    },
    "markdown.directive.command_summary": {
      "node": {
        "field": "summary",
        "kind": "command"
      }
    },
    "markdown.directive.kind": {
      "node": {
        "field": "kind",
        "kind": "document"
      }
    },
    "markdown.directive.status": {
      "node": {
        "field": "status",
        "kind": "document"
      }
    },
    "markdown.directive.blocked_by": {
      "emit": {
        "relation": "blocked_by",
        "target": "path",
        "target_kind": "document"
      }
    },
    "markdown.directive.decided_by": {
      "emit": {
        "relation": "decided_by",
        "target": "path",
        "target_kind": "document"
      }
    },
    "markdown.directive.implements": {
      "emit": {
        "relation": "implements",
        "target": "path",
        "target_kind": "document"
      }
    },
    "markdown.directive.implements_command": {
      "emit": {
        "relation": "implements_command",
        "target": "path",
        "target_kind": "command"
      }
    },
    "markdown.directive.term": {
      "emit": {
        "relation": "defines",
        "target": "value",
        "target_kind": "term"
      },
      "node": {
        "field": "title",
        "key": "value",
        "kind": "term"
      }
    },
    "markdown.directive.term_definition": {
      "node": {
        "field": "definition",
        "kind": "term"
      }
    },
    "markdown.directive.tracked_in": {
      "emit": {
        "relation": "tracked_in",
        "target": "path",
        "target_kind": "document"
      }
    },
    "markdown.directive.uses_term": {
      "emit": {
        "relation": "uses_term",
        "target": "path",
        "target_kind": "term"
      }
    },
    "markdown.link": {
      "emit": {
        "relation": "links_to",
        "target": "path",
        "target_kind": "document"
      }
    }
  }
}
