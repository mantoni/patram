{
  "include": [
    "docs/**/*.md",
    "docs/**/*.yaml",
    "docs/**/*.yml",
    "bin/**/*.js",
    "lib/**/*.js",
    "scripts/**/*.js",
    "test/**/*.js"
  ],
  "queries": {
    "accepted-decisions": {
      "description": "Show accepted decisions.",
      "cypher": "MATCH (n:Decision) WHERE n.status = 'accepted' RETURN n"
    },
    "active-plans": {
      "description": "Show active implementation plans.",
      "cypher": "MATCH (n:Plan) WHERE n.status = 'active' RETURN n"
    },
    "active-roadmaps": {
      "description": "Show active roadmaps.",
      "cypher": "MATCH (n:Roadmap) WHERE n.status = 'active' RETURN n"
    },
    "blocked-tasks": {
      "description": "Show blocked tasks.",
      "cypher": "MATCH (n:Task) WHERE n.status = 'blocked' RETURN n"
    },
    "command-implementations": {
      "description": "Show source anchors that implement documented commands.",
      "cypher": "MATCH (n) WHERE EXISTS { MATCH (n)-[:IMPLEMENTS_COMMAND]->(command:Command) } RETURN n"
    },
    "command-taxonomy": {
      "description": "Show canonical command reference nodes.",
      "cypher": "MATCH (n:Command) RETURN n"
    },
    "decision-review-queue": {
      "description": "Show proposed decisions awaiting review.",
      "cypher": "MATCH (n:Decision) WHERE n.status = 'proposed' RETURN n"
    },
    "decisions-needing-tasks": {
      "description": "Show accepted decisions that do not yet have tasks.",
      "cypher": "MATCH (n:Decision) WHERE n.status = 'accepted' AND COUNT { MATCH (task:Task)-[:DECIDED_BY]->(n) } = 0 RETURN n"
    },
    "decisions-with-open-tasks": {
      "description": "Show accepted decisions with unfinished tasks.",
      "cypher": "MATCH (n:Decision) WHERE n.status = 'accepted' AND EXISTS { MATCH (task:Task)-[:DECIDED_BY]->(n) WHERE task.status NOT IN ['done', 'dropped', 'superseded'] } RETURN n"
    },
    "ideas": {
      "description": "Show captured, exploring, and planned ideas.",
      "cypher": "MATCH (n:Idea) WHERE n.status IN ['captured', 'exploring', 'planned'] RETURN n"
    },
    "in-progress-tasks": {
      "description": "Show tasks currently in progress.",
      "cypher": "MATCH (n:Task) WHERE n.status = 'in_progress' RETURN n"
    },
    "pending-tasks": {
      "description": "Show tasks that have not started yet.",
      "cypher": "MATCH (n:Task) WHERE n.status = 'pending' RETURN n"
    },
    "plans-with-open-tasks": {
      "description": "Show active plans with unfinished tasks.",
      "cypher": "MATCH (n:Plan) WHERE n.status = 'active' AND EXISTS { MATCH (task:Task)-[:TRACKED_IN]->(n) WHERE task.status NOT IN ['done', 'dropped', 'superseded'] } RETURN n"
    },
    "plans-without-decisions": {
      "description": "Show active plans that are missing linked decisions.",
      "cypher": "MATCH (n:Plan) WHERE n.status = 'active' AND NOT EXISTS { MATCH (decision:Decision)-[:TRACKED_IN]->(n) } RETURN n"
    },
    "ready-tasks": {
      "description": "Show tasks that are ready to start.",
      "cypher": "MATCH (n:Task) WHERE n.status = 'ready' RETURN n"
    },
    "source-entrypoints": {
      "description": "Show documented entrypoint source anchors.",
      "cypher": "MATCH (n) WHERE n.kind = 'entrypoint' RETURN n"
    },
    "source-cli": {
      "description": "Show CLI-related source anchors.",
      "cypher": "MATCH (n) WHERE n.kind = 'cli' RETURN n"
    },
    "source-config": {
      "description": "Show config-related source anchors.",
      "cypher": "MATCH (n) WHERE n.kind = 'config' RETURN n"
    },
    "source-scan": {
      "description": "Show scan-related source anchors.",
      "cypher": "MATCH (n) WHERE n.kind = 'scan' RETURN n"
    },
    "source-parse": {
      "description": "Show parse-related source anchors.",
      "cypher": "MATCH (n) WHERE n.kind = 'parse' RETURN n"
    },
    "source-graph": {
      "description": "Show graph-related source anchors.",
      "cypher": "MATCH (n) WHERE n.kind = 'graph' RETURN n"
    },
    "source-output": {
      "description": "Show output-related source anchors.",
      "cypher": "MATCH (n) WHERE n.kind = 'output' RETURN n"
    },
    "source-support": {
      "description": "Show support source anchors.",
      "cypher": "MATCH (n) WHERE n.kind = 'support' RETURN n"
    },
    "source-release": {
      "description": "Show release-related source anchors.",
      "cypher": "MATCH (n) WHERE n.kind = 'release' RETURN n"
    },
    "term-usage": {
      "description": "Show nodes that use canonical terms.",
      "cypher": "MATCH (n) WHERE EXISTS { MATCH (n)-[:USES_TERM]->(term:Term) } RETURN n"
    },
    "term-taxonomy": {
      "description": "Show canonical term reference nodes.",
      "cypher": "MATCH (n:Term) RETURN n"
    }
  },
  "classes": {
    "command": {
      "label": "Command",
      "schema": {
        "fields": {
          "summary": {
            "presence": "optional"
          }
        },
        "unknown_fields": "ignore"
      }
    },
    "convention": {
      "label": "Convention",
      "schema": {
        "document_path_class": "convention_docs",
        "fields": {
          "status": {
            "presence": "optional"
          }
        },
        "unknown_fields": "ignore"
      }
    },
    "decision": {
      "label": "Decision",
      "schema": {
        "document_path_class": "decision_docs",
        "fields": {
          "status": {
            "presence": "optional"
          }
        },
        "unknown_fields": "ignore"
      }
    },
    "document": {
      "builtin": true,
      "schema": {
        "fields": {
          "description": {
            "presence": "optional"
          },
          "kind": {
            "presence": "optional"
          },
          "status": {
            "presence": "optional"
          }
        },
        "unknown_fields": "ignore"
      }
    },
    "idea": {
      "label": "Idea",
      "schema": {
        "document_path_class": "idea_docs",
        "fields": {
          "status": {
            "presence": "optional"
          }
        },
        "unknown_fields": "ignore"
      }
    },
    "plan": {
      "label": "Plan",
      "schema": {
        "document_path_class": "plan_docs",
        "fields": {
          "status": {
            "presence": "optional"
          }
        },
        "unknown_fields": "ignore"
      }
    },
    "roadmap": {
      "label": "Roadmap",
      "schema": {
        "document_path_class": "roadmap_docs",
        "fields": {
          "status": {
            "presence": "optional"
          }
        },
        "unknown_fields": "ignore"
      }
    },
    "task": {
      "label": "Task",
      "schema": {
        "document_path_class": "task_docs",
        "fields": {
          "status": {
            "presence": "optional"
          }
        },
        "unknown_fields": "ignore"
      }
    },
    "term": {
      "label": "Term",
      "schema": {
        "fields": {
          "definition": {
            "presence": "optional"
          }
        },
        "unknown_fields": "ignore"
      }
    }
  },
  "fields": {
    "description": {
      "display": {
        "hidden": true
      },
      "type": "string"
    },
    "definition": {
      "type": "string"
    },
    "kind": {
      "type": "enum",
      "values": [
        "cli",
        "config",
        "discovery",
        "entrypoint",
        "graph",
        "output",
        "parse",
        "release",
        "scan",
        "support"
      ]
    },
    "status": {
      "type": "enum",
      "values": [
        "accepted",
        "active",
        "blocked",
        "captured",
        "done",
        "dropped",
        "exploring",
        "in_progress",
        "pending",
        "planned",
        "proposed",
        "ready",
        "superseded"
      ]
    },
    "summary": {
      "type": "string"
    }
  },
  "path_classes": {
    "convention_docs": {
      "prefixes": ["docs/conventions/"]
    },
    "decision_docs": {
      "prefixes": ["docs/decisions/"]
    },
    "idea_docs": {
      "prefixes": ["docs/research/"]
    },
    "plan_docs": {
      "prefixes": ["docs/plans/"]
    },
    "roadmap_docs": {
      "prefixes": ["docs/roadmap/"]
    },
    "task_docs": {
      "prefixes": ["docs/tasks/"]
    }
  },
  "relations": {
    "defines": {
      "from": ["document"],
      "to": ["command", "term"]
    },
    "about_command": {
      "from": ["document"],
      "to": ["command"]
    },
    "links_to": {
      "builtin": true,
      "from": ["document"],
      "to": ["document"]
    },
    "blocked_by": {
      "from": ["document"],
      "to": ["document"]
    },
    "decided_by": {
      "from": ["document"],
      "to": ["document"]
    },
    "implements": {
      "from": ["document"],
      "to": ["document"]
    },
    "implements_command": {
      "from": ["document"],
      "to": ["command"]
    },
    "tracked_in": {
      "from": ["document"],
      "to": ["document"]
    },
    "uses_term": {
      "from": ["document"],
      "to": ["term"]
    }
  },
