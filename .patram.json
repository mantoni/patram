{
  "include": [
    "docs/**/*.md",
    "docs/**/*.yaml",
    "docs/**/*.yml",
    "bin/**/*.js",
    "lib/**/*.js",
    "scripts/**/*.js",
    "test/**/*.js"
  ],
  "queries": {
    "accepted-decisions": {
      "where": "$class=decision and status=accepted"
    },
    "active-plans": {
      "where": "$class=plan and status=active"
    },
    "active-roadmaps": {
      "where": "$class=roadmap and status=active"
    },
    "blocked-tasks": {
      "where": "$class=task and status=blocked"
    },
    "command-implementations": {
      "where": "implements_command:*"
    },
    "command-taxonomy": {
      "where": "$id^=command:"
    },
    "decision-review-queue": {
      "where": "$class=decision and status=proposed"
    },
    "decisions-needing-tasks": {
      "where": "$class=decision and status=accepted and count(in:decided_by, $class=task) = 0"
    },
    "decisions-with-open-tasks": {
      "where": "$class=decision and status=accepted and any(in:decided_by, $class=task and status not in [done, dropped, superseded])"
    },
    "ideas": {
      "where": "$class=idea and status in [captured, exploring, planned]"
    },
    "in-progress-tasks": {
      "where": "$class=task and status=in_progress"
    },
    "pending-tasks": {
      "where": "$class=task and status=pending"
    },
    "plans-with-open-tasks": {
      "where": "$class=plan and status=active and any(in:tracked_in, $class=task and status not in [done, dropped, superseded])"
    },
    "plans-without-decisions": {
      "where": "$class=plan and status=active and none(in:tracked_in, $class=decision)"
    },
    "ready-tasks": {
      "where": "$class=task and status=ready"
    },
    "source-entrypoints": {
      "where": "kind=entrypoint"
    },
    "source-cli": {
      "where": "kind=cli"
    },
    "source-config": {
      "where": "kind=config"
    },
    "source-scan": {
      "where": "kind=scan"
    },
    "source-parse": {
      "where": "kind=parse"
    },
    "source-graph": {
      "where": "kind=graph"
    },
    "source-output": {
      "where": "kind=output"
    },
    "source-support": {
      "where": "kind=support"
    },
    "source-release": {
      "where": "kind=release"
    },
    "term-usage": {
      "where": "uses_term:*"
    },
    "term-taxonomy": {
      "where": "$id^=term:"
    }
  },
  "derived_summaries": {
    "decision_execution": {
      "classes": ["decision"],
      "fields": [
        {
          "name": "execution",
          "select": [
            {
              "when": "count(in:decided_by, $class=task) > 0 and none(in:decided_by, $class=task and status not in [done, dropped, superseded])",
              "value": "done"
            },
            {
              "when": "any(in:decided_by, $class=task and status not in [done, dropped, superseded]) and none(in:decided_by, $class=task and status not in [done, dropped, superseded] and not status=blocked)",
              "value": "blocked"
            },
            {
              "when": "any(in:decided_by, $class=task and not status=pending)",
              "value": "in_progress"
            }
          ],
          "default": "not_started"
        },
        {
          "name": "open_tasks",
          "count": {
            "traversal": "in:decided_by",
            "where": "$class=task and status not in [done, dropped, superseded]"
          }
        },
        {
          "name": "blocked_tasks",
          "count": {
            "traversal": "in:decided_by",
            "where": "$class=task and status=blocked"
          }
        },
        {
          "name": "total_tasks",
          "count": {
            "traversal": "in:decided_by",
            "where": "$class=task"
          }
        }
      ]
    },
    "plan_execution": {
      "classes": ["plan"],
      "fields": [
        {
          "name": "execution",
          "select": [
            {
              "when": "count(in:tracked_in, $class=task) > 0 and none(in:tracked_in, $class=task and status not in [done, dropped, superseded])",
              "value": "done"
            },
            {
              "when": "any(in:tracked_in, $class=task and status not in [done, dropped, superseded]) and none(in:tracked_in, $class=task and status not in [done, dropped, superseded] and not status=blocked)",
              "value": "blocked"
            },
            {
              "when": "any(in:tracked_in, $class=task and not status=pending)",
              "value": "in_progress"
            }
          ],
          "default": "not_started"
        },
        {
          "name": "open_tasks",
          "count": {
            "traversal": "in:tracked_in",
            "where": "$class=task and status not in [done, dropped, superseded]"
          }
        },
        {
          "name": "blocked_tasks",
          "count": {
            "traversal": "in:tracked_in",
            "where": "$class=task and status=blocked"
          }
        },
        {
          "name": "total_tasks",
          "count": {
            "traversal": "in:tracked_in",
            "where": "$class=task"
          }
        }
      ]
    }
  },
  "classes": {
    "command": {
      "label": "Command",
      "schema": {
        "fields": {
          "summary": {
            "presence": "optional"
          }
        },
        "unknown_fields": "ignore"
      }
    },
    "convention": {
      "label": "Convention",
      "schema": {
        "document_path_class": "convention_docs",
        "fields": {
          "status": {
            "presence": "optional"
          }
        },
        "unknown_fields": "ignore"
      }
    },
    "decision": {
      "label": "Decision",
      "schema": {
        "document_path_class": "decision_docs",
        "fields": {
          "status": {
            "presence": "optional"
          }
        },
        "unknown_fields": "ignore"
      }
    },
    "document": {
      "builtin": true,
      "schema": {
        "fields": {
          "description": {
            "presence": "optional"
          },
          "kind": {
            "presence": "optional"
          },
          "status": {
            "presence": "optional"
          }
        },
        "unknown_fields": "ignore"
      }
    },
    "idea": {
      "label": "Idea",
      "schema": {
        "document_path_class": "idea_docs",
        "fields": {
          "status": {
            "presence": "optional"
          }
        },
        "unknown_fields": "ignore"
      }
    },
    "plan": {
      "label": "Plan",
      "schema": {
        "document_path_class": "plan_docs",
        "fields": {
          "status": {
            "presence": "optional"
          }
        },
        "unknown_fields": "ignore"
      }
    },
    "roadmap": {
      "label": "Roadmap",
      "schema": {
        "document_path_class": "roadmap_docs",
        "fields": {
          "status": {
            "presence": "optional"
          }
        },
        "unknown_fields": "ignore"
      }
    },
    "task": {
      "label": "Task",
      "schema": {
        "document_path_class": "task_docs",
        "fields": {
          "status": {
            "presence": "optional"
          }
        },
        "unknown_fields": "ignore"
      }
    },
    "term": {
      "label": "Term",
      "schema": {
        "fields": {
          "definition": {
            "presence": "optional"
          }
        },
        "unknown_fields": "ignore"
      }
    }
  },
  "fields": {
    "description": {
      "display": {
        "hidden": true
      },
      "type": "string"
    },
    "definition": {
      "type": "string"
    },
    "kind": {
      "type": "enum",
      "values": [
        "cli",
        "config",
        "discovery",
        "entrypoint",
        "graph",
        "output",
        "parse",
        "release",
        "scan",
        "support"
      ]
    },
    "status": {
      "type": "enum",
      "values": [
        "accepted",
        "active",
        "blocked",
        "captured",
        "done",
        "dropped",
        "exploring",
        "in_progress",
        "pending",
        "planned",
        "proposed",
        "ready",
        "superseded"
      ]
    },
    "summary": {
      "type": "string"
    }
  },
  "path_classes": {
    "convention_docs": {
      "prefixes": ["docs/conventions/"]
    },
    "decision_docs": {
      "prefixes": ["docs/decisions/"]
    },
    "idea_docs": {
      "prefixes": ["docs/research/"]
    },
    "plan_docs": {
